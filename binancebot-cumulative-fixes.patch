+// Fix: Инициализация TelegramBotClient
+using Telegram.Bot;
+using Telegram.Bot.Types;
+using Telegram.Bot.Exceptions;
+using System.Net.Http;
+
+namespace BinanceBot.Services
+{
+    public class TelegramBotService
+    {
+        private TelegramBotClient? _botClient;
+        private readonly ILogger<TelegramBotService> _logger;
+        private readonly HttpClient _httpClient;
+
+        public TelegramBotService(ILogger<TelegramBotService> logger, HttpClient httpClient)
+        {
+            _logger = logger;
+            _httpClient = httpClient;
+        }
+
+        public async Task InitializeAsync(string token)
+        {
+            try
+            {
+                if (string.IsNullOrEmpty(token))
+                {
+                    _logger.LogWarning("Telegram токен не настроен. Бот будет работать без уведомлений.");
+                    return;
+                }
+
+                TelegramBotClientOptions options = new TelegramBotClientOptions(token);
+                _botClient = new TelegramBotClient(options, _httpClient);
+
+                var me = await _botClient.GetMeAsync();
+                _logger.LogInformation("✅ Telegram бот успешно инициализирован: @{Username}", me.Username);
+            }
+            catch (Exception ex)
+            {
+                _logger.LogError(ex, "❌ Ошибка инициализации Telegram. Работа продолжается в автономном режиме.");
+                _botClient = null;
+            }
+        }
+
+        public async Task SendMessageAsync(long chatId, string text)
+        {
+            if (_botClient == null || chatId == 0) return;
+
+            try
+            {
+                await _botClient.SendTextMessageAsync(chatId, text);
+            }
+            catch (ApiRequestException ex)
+            {
+                _logger.LogWarning(ex, "Не удалось отправить сообщение в Telegram: {Message}", ex.Message);
+            }
+        }
+    }
+}
+
