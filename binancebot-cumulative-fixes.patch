+// Fix: Исправление спама OCO-ордерами (Insufficient Balance) + Exponential Backoff
+using Binance.Net.Objects.Models.Spot;
+using System;
+using System.Linq;
+using System.Threading.Tasks;
+
+namespace BinanceBot.Services
+{
+    public partial class TradingService
+    {
+        public async Task<bool> PlaceOcoOrderAsync(string symbol, decimal quantity, decimal takeProfitPrice, decimal stopLossPrice, int retryCount = 1)
+        {
+            const int MaxRetries = 3;
+
+            try
+            {
+                var accountInfo = await _binanceClient.GetAccountInfoAsync();
+                var baseAsset = symbol.Replace("USDC", "").Replace("USDT", "");
+                var assetBalance = accountInfo.Balances.FirstOrDefault(b => b.Asset == baseAsset);
+
+                if (assetBalance == null || assetBalance.Free < quantity)
+                {
+                    _logger.LogWarning("⚠️ Недостаточно свободного {Asset} для OCO. В наличии: {Free}, Требуется: {Qty}. Ждем разблокировки пула...", baseAsset, assetBalance?.Free ?? 0, quantity);
+
+                    if (retryCount <= MaxRetries)
+                    {
+                        var delay = TimeSpan.FromSeconds(Math.Pow(2, retryCount));
+                        _logger.LogInformation("⏳ Ожидание {Delay}с перед повторной попыткой OCO ({Attempt}/{Max})...", delay.TotalSeconds, retryCount, MaxRetries);
+                        await Task.Delay(delay);
+                        return await PlaceOcoOrderAsync(symbol, quantity, takeProfitPrice, stopLossPrice, retryCount + 1);
+                    }
+
+                    _logger.LogError("❌ Превышен лимит попыток OCO для {Symbol}. Перевод стратегии в режим удержания.", symbol);
+                    return false;
+                }
+
+                var orderResult = await _binanceClient.PlaceOcoOrderAsync(symbol, quantity, takeProfitPrice, stopLossPrice);
+
+                if (!orderResult.Success)
+                {
+                    _logger.LogError("PlaceOcoOrder ERROR for {Symbol}: {Error}", symbol, orderResult.Error);
+                    if (orderResult.Error.Contains("-2010") && retryCount <= MaxRetries)
+                    {
+                        await Task.Delay(TimeSpan.FromSeconds(3));
+                        return await PlaceOcoOrderAsync(symbol, quantity, takeProfitPrice, stopLossPrice, retryCount + 1);
+                    }
+                    return false;
+                }
+
+                _logger.LogInformation("✅ OCO ордер успешно размещен для {Symbol}", symbol);
+                return true;
+            }
+            catch (Exception ex)
+            {
+                _logger.LogError(ex, "Критическая ошибка при попытке поставить OCO ордер для {Symbol}", symbol);
+                return false;
+            }
+        }
+    }
+}
