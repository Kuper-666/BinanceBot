+// Fix: Обновление пакетов Telegram.Bot до стабильной версии с копированием ML модели
+<Project Sdk="Microsoft.NET.Sdk">
+  <PropertyGroup>
+    <OutputType>Exe</OutputType>
+    <TargetFramework>net8.0</TargetFramework>
+    <ImplicitUsings>enable</ImplicitUsings>
+    <Nullable>enable</Nullable>
+    <ServerGarbageCollection>true</ServerGarbageCollection>
+  </PropertyGroup>
+
+  <ItemGroup>
+    <!-- Обновлено для совместимости конструктора TelegramBotClient -->
+    <PackageReference Include="Telegram.Bot" Version="19.0.0" />
+    <PackageReference Include="Binance.Net" Version="9.2.1" />
+    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.16.3" />
+  </ItemGroup>
+
+  <!-- Гарантия копирования ML модели при компиляции -->
+  <ItemGroup>
+    <None Update="Models\trading_model.onnx">
+      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
+    </None>
+  </ItemGroup>
