+// Fix: Обработка отсутствия ML Модели (поиск по нескольким путям + эвристический fallback)
+using Microsoft.ML.OnnxRuntime;
+using System;
+using System.IO;
+using System.Linq;
+
+namespace BinanceBot.Services
+{
+    public class MLService
+    {
+        private InferenceSession? _session;
+        private readonly ILogger<MLService> _logger;
+        private bool _isUsingFallback = false;
+
+        private readonly string[] _candidatePaths = new[]
+        {
+            "Models/trading_model.onnx",
+            "ML/trading_model.onnx",
+            Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Models", "trading_model.onnx"),
+            Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "trading_model.onnx")
+        };
+
+        public MLService(ILogger<MLService> logger)
+        {
+            _logger = logger;
+            InitializeModel();
+        }
+
+        private void InitializeModel()
+        {
+            string? foundPath = _candidatePaths.FirstOrDefault(File.Exists);
+
+            if (foundPath == null)
+            {
+                _logger.LogWarning("⚠️ ML модель ONNX не найдена ни в одном из стандартных путей.");
+                _logger.LogInformation("ℹ️ Включается резервная эвристическая фильтрация (RSI + Volatility + SMA) вместо нейросети.");
+                _isUsingFallback = true;
+                return;
+            }
+
+            try
+            {
+                _session = new InferenceSession(foundPath);
+                _logger.LogInformation("✅ ML модель успешно загружена из: {Path}", foundPath);
+                _isUsingFallback = false;
+            }
+            catch (Exception ex)
+            {
+                _logger.LogError(ex, "❌ Ошибка инициализации сессии OnnxRuntime. Включен резервный режим.");
+                _isUsingFallback = true;
+            }
+        }
+
+        public bool EvaluateSignal(string symbol, decimal rsi, decimal volatility, decimal macd)
+        {
+            if (_isUsingFallback || _session == null)
+            {
+                // Эвристическое резервное правило, работающее без ML модели
+                return rsi < 32m && volatility > 0.45m && macd > 0;
+            }
+
+            // Логика прогноза через OnnxRuntime...
+            return true;
+        }
+    }
+}
+
