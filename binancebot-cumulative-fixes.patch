+// Fix: Защита от NullReferenceException при обновлении пар + SemaphoreSlim
+using System;
+using System.Collections.Generic;
+using System.Linq;
+using System.Threading;
+using System.Threading.Tasks;
+
+namespace BinanceBot.Services
+{
+    public partial class MarketDataService
+    {
+        private readonly SemaphoreSlim _pairsSemaphore = new SemaphoreSlim(1, 1);
+        private List<TradingPair>? _tradingPairs = new List<TradingPair>();
+
+        public async Task UpdateTradingPairsAsync()
+        {
+            await _pairsSemaphore.WaitAsync();
+            try
+            {
+                if (_tradingPairs == null || _tradingPairs.Count == 0)
+                {
+                    _logger.LogWarning("⚠️ Коллекция торговых пар пуста или сброшена оптимизатором. Выполняем переинициализацию...");
+                    _tradingPairs = await LoadTradingPairsFromConfigAsync();
+
+                    if (_tradingPairs == null || _tradingPairs.Count == 0)
+                    {
+                        _logger.LogError("❌ Не удалось загрузить торговые пары из конфигурации.");
+                        return;
+                    }
+                }
+
+                foreach (var pair in _tradingPairs.ToList())
+                {
+                    if (pair == null || string.IsNullOrEmpty(pair.Symbol)) continue;
+
+                    var ticker = await _binanceClient.GetTickerAsync(pair.Symbol);
+                    if (ticker != null)
+                    {
+                        pair.CurrentPrice = ticker.Price;
+                        _logger.LogDebug("Обновлена пара {Symbol}: {Price}", pair.Symbol, pair.CurrentPrice);
+                    }
+                }
+            }
+            catch (Exception ex)
+            {
+                _logger.LogError(ex, "❌ Ошибка при обновлении торговых пар: {Message}", ex.Message);
+            }
+            finally
+            {
+                _pairsSemaphore.Release();
+            }
+        }
+
+        public async Task LockAndReloadPairsAsync(List<TradingPair> newPairs)
+        {
+            await _pairsSemaphore.WaitAsync();
+            try
+            {
+                _tradingPairs = newPairs;
+                _logger.LogInformation("✅ Список торговых пар успешно обновлен оптимизатором.");
+            }
+            finally
+            {
+                _pairsSemaphore.Release();
+            }
+        }
+    }
+}
