# Default: auto-detect text, normalize to LF in the repo.
* text=auto eol=lf

# --- Source code (canonical LF in repo) ---
*.cs      text eol=lf
*.csproj  text eol=lf
*.sln     text eol=lf
*.xaml    text eol=lf
*.py      text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.csv     text eol=lf
*.txt     text eol=lf
*.editorconfig text eol=lf

# --- Generated files we never want to touch ---
*.patch   binary

# --- Binary assets (never normalize) ---
*.zip     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     text eol=lf
*.pdf     binary
*.dll     binary
*.exe     binary
*.pdb     binary
*.snk     binary

# --- Git metadata ---
.gitignore    text eol=lf
.gitattributes text eol=lf
