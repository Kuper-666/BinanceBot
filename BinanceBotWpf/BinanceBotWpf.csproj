<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows</TargetFramework>
		<UseWPF>true</UseWPF>
		<StartupUri>MainWindow.xaml</StartupUri>
		<Version>1.0.130</Version>

		<!-- Single file publication - ОДИН .EXE ФАЙЛ -->
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<PublishSingleFile>true</PublishSingleFile>
		<SelfContained>true</SelfContained>
		<PublishTrimmed>false</PublishTrimmed>
		<PublishReadyToRun>true</PublishReadyToRun>
		<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
		<EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
		<DebugType>embedded</DebugType>

		<!-- Optimizations -->
		<TieredCompilation>true</TieredCompilation>
		<TieredCompilationQuickJit>true</TieredCompilationQuickJit>

		<!-- Remove unnecessary files -->
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	</PropertyGroup>

	<!-- NuGet packages -->
	<ItemGroup>
		<PackageReference Include="Binance.Net" Version="12.13.0" />
		<PackageReference Include="CsvHelper" Version="33.1.0" />
		<PackageReference Include="LiveChartsCore.SkiaSharpView.WPF" Version="2.0.4" />
		<PackageReference Include="Microsoft.ML" Version="5.0.0" />
		<PackageReference Include="Microsoft.ML.FastTree" Version="5.0.0" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
		<PackageReference Include="OxyPlot.Wpf" Version="2.2.0" />
		<PackageReference Include="Telegram.Bot" Version="22.10.0.1" />
	</ItemGroup>

	<!-- Embedded resources - встраиваемые ресурсы -->
	<ItemGroup>
		<EmbeddedResource Include="Resources\trading_model.zip" />
		<Resource Include="Resources\binance_bot.ico">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Resource>
	</ItemGroup>

	<!-- Source files -->
	<ItemGroup>
		<Compile Remove="DataDownloader\**" />
		<Compile Remove="Python\**" />
		<EmbeddedResource Remove="DataDownloader\**" />
		<EmbeddedResource Remove="Python\**" />
		<None Remove="DataDownloader\**" />
		<None Remove="Python\**" />
	</ItemGroup>
</Project>