<Window x:Class="BinanceBotWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Binance Trading Bot" 
        Height="650" Width="950" 
        Background="#121212">

    <Window.Resources>
        <!-- Стиль для заголовков столбцов (общий для всех DataGrid) -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2c3e50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#34495e"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="130"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Command="{Binding StartCommand}" Content="ЗАПУСК" Width="100" Height="30" Background="#2ecc71" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
            <Button Command="{Binding StopCommand}"  Content="СТОП"   Width="100" Height="30" Background="#e74c3c" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>

            <TextBlock Text="SMA:" Foreground="#bdc3c7" Margin="20,0,5,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding FastSma, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#2c3e50" Foreground="White" Margin="0,0,5,0"/>
            <TextBox Text="{Binding SlowSma, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#2c3e50" Foreground="White" Margin="0,0,15,0"/>

            <TextBlock Text="RSI buy &lt;" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding RsiBuyThreshold, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#2c3e50" Foreground="White" Margin="0,0,5,0"/>
            <TextBlock Text="RSI sell &gt;" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding RsiSellThreshold, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#2c3e50" Foreground="White"/>

            <TextBlock Text="SL %" Foreground="#bdc3c7" Margin="10,0,5,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding StopLossPercent, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#2c3e50" Foreground="White" Margin="0,0,5,0"/>
            <TextBlock Text="TP %" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding TakeProfitPercent, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#2c3e50" Foreground="White" Margin="0,0,5,0"/>
            <TextBlock Text="Trail %" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding TrailingStopPercent, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#2c3e50" Foreground="White"/>
        </WrapPanel>

        <!-- Баланс и статус -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Foreground="#2ecc71" FontWeight="Bold" FontSize="18">
                <Run Text="USDC BALANCE: "/>
                <Run Text="{Binding WalletBalance}"/>
            </TextBlock>
            <TextBlock Foreground="#f39c12" FontWeight="Bold" FontSize="14" Margin="30,0,0,0" Text="{Binding PositionsStatusText}"/>
        </StackPanel>
        <TextBlock Grid.Row="2" Foreground="#3498db" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Text="{Binding RiskPercentDisplay}"/>

        <!-- Вкладки -->
        <TabControl Grid.Row="3" Background="Transparent" Foreground="White">
            <!-- Вкладка Торговля -->
            <TabItem Header="Торговля" Background="#1e1e1e" Foreground="White">
                <DataGrid x:Name="TradingDataGrid" ItemsSource="{Binding PairsList}" 
                          AutoGenerateColumns="False" HeadersVisibility="Column"
                          Background="#121212" Foreground="White"
                          BorderThickness="0" FontSize="14"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single" RowHeight="32"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeColumns="True" CanUserSortColumns="True">

                    <DataGrid.Resources>
                        <!-- Стиль строки для цветов из PairAnalysisItem -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{Binding RowColor}"/>
                            <Setter Property="Foreground" Value="{Binding ForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#34495e"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <!-- Стиль ячейки -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{Binding ForegroundBrush}"/>
                            <Setter Property="Background" Value="{Binding RowColor}"/>
                            <Setter Property="BorderBrush" Value="#2c3e50"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ПАРА"      Binding="{Binding Pair}"     Width="120" />
                        <DataGridTextColumn Header="ЦЕНА"      Binding="{Binding Price}"    Width="120" />
                        <DataGridTextColumn Header="СИГНАЛ"    Binding="{Binding Analysis}" Width="*"   />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Вкладка История сделок -->
            <TabItem Header="История сделок" Background="#1e1e1e" Foreground="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Блок статистики -->
                    <Border Grid.Row="0" Background="#252525" Margin="0,0,0,10" Padding="10" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Общий PnL" Foreground="#bdc3c7" FontSize="12"/>
                                <TextBlock Foreground="#2ecc71" FontSize="16" FontWeight="Bold" Margin="0,5,0,0">
                                    <Run Text="{Binding TotalPnL, StringFormat=F2}"/>
                                    <Run Text=" USDC"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Win Rate" Foreground="#bdc3c7" FontSize="12"/>
                                <TextBlock Foreground="#2ecc71" FontSize="16" FontWeight="Bold" Margin="0,5,0,0">
                                    <Run Text="{Binding WinRate, StringFormat=F1}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Сделок" Foreground="#bdc3c7" FontSize="12"/>
                                <TextBlock Text="{Binding TotalTrades}" Foreground="#f39c12" FontSize="16" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Выигрышей" Foreground="#bdc3c7" FontSize="12"/>
                                <TextBlock Text="{Binding WinningTrades}" Foreground="#2ecc71" FontSize="16" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Проигрышей" Foreground="#bdc3c7" FontSize="12"/>
                                <TextBlock Text="{Binding LosingTrades}" Foreground="#e74c3c" FontSize="16" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="5">
                                <TextBlock Text="Лучшая/Худшая" Foreground="#bdc3c7" FontSize="12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding BestPnL, StringFormat=F2}" Foreground="#2ecc71" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text=" / " Foreground="#bdc3c7" FontSize="14"/>
                                    <TextBlock Text="{Binding WorstPnL, StringFormat=F2}" Foreground="#e74c3c" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Макс. просадка" Foreground="#bdc3c7" FontSize="12"/>
                                <TextBlock Text="{Binding MaxDrawdownDisplay}" Foreground="#e74c3c" FontSize="14" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="7">
                                <TextBlock Text="Ср. приб/убыток" Foreground="#bdc3c7" FontSize="12"/>
                                <TextBlock Text="{Binding AvgProfitLossDisplay}" Foreground="#f39c12" FontSize="12" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Таблица истории с чередованием строк -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding TradesHistory}" 
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              Background="#121212" Foreground="White"
                              BorderThickness="0" FontSize="12"
                              GridLinesVisibility="Horizontal"
                              AlternationCount="2"
                              RowHeight="30" CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeColumns="True" CanUserSortColumns="True">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="#1e1e1e"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                        <Setter Property="Background" Value="#252525"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#34495e"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время открытия" Binding="{Binding OpenTime, StringFormat='HH:mm:ss dd.MM'}" Width="110"/>
                            <DataGridTextColumn Header="Время закрытия" Binding="{Binding CloseTime, StringFormat='HH:mm:ss dd.MM'}" Width="110"/>
                            <DataGridTextColumn Header="Пара" Binding="{Binding Symbol}" Width="80"/>
                            <DataGridTextColumn Header="Цена входа" Binding="{Binding EntryPrice, StringFormat=F4}" Width="85"/>
                            <DataGridTextColumn Header="Цена выхода" Binding="{Binding ExitPrice, StringFormat=F4}" Width="85"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, StringFormat=F6}" Width="90"/>
                            <DataGridTextColumn Header="PnL (USDC)" Binding="{Binding PnL, StringFormat=F2}" Width="90"/>
                            <DataGridTextColumn Header="PnL %" Binding="{Binding PnLPercent, StringFormat=F2}" Width="70"/>
                            <DataGridTextColumn Header="Длительность" Binding="{Binding Duration, StringFormat='hh\\:mm\\:ss'}" Width="85"/>
                            <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Акции США" Background="#1e1e1e" Foreground="White">
                <DataGrid ItemsSource="{Binding StocksList}" 
              AutoGenerateColumns="False" HeadersVisibility="Column"
              Background="#121212" Foreground="White"
              BorderThickness="0" FontSize="14"
              GridLinesVisibility="Horizontal"
              SelectionMode="Single" RowHeight="32"
              CanUserAddRows="False" CanUserDeleteRows="False"
              CanUserResizeColumns="True" CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Символ" Binding="{Binding Symbol}" Width="120" />
                        <DataGridTextColumn Header="Цена, USDC" Binding="{Binding Price, StringFormat=F2}" Width="140" />
                        <DataGridTextColumn Header="Изм. за 24ч, %" Binding="{Binding ChangePercent, StringFormat=F2}" Width="140" />
                        <DataGridTextColumn Header="Объём, USDC" Binding="{Binding Volume, StringFormat=N0}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Вкладка Баланс -->
            <TabItem Header="Баланс" Background="#1e1e1e" Foreground="White">
                <oxy:PlotView Model="{Binding PlotModel}" Background="#1e1e1e"/>
            </TabItem>
        </TabControl>

        <TextBox Grid.Row="4" x:Name="LogTextBox" Text="{Binding SystemLogs, Mode=OneWay}" 
                 Background="#1e1e1e" Foreground="#bdc3c7" 
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                 Margin="0,10,0,0" Padding="5"/>
    </Grid>
</Window>