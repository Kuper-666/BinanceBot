<Window x:Class="BinanceBotWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Binance Trading Bot v2.0" 
        Height="700" Width="1300" 
        Background="#121212"
        WindowStartupLocation="CenterScreen"
        MinHeight="600" MinWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="▶ ЗАПУСК" Width="100" Height="32" Background="#2ecc71" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding StartCommand}" Margin="0,0,8,0"/>
            <Button Content="⏹ СТОП" Width="100" Height="32" Background="#e74c3c" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding StopCommand}" Margin="0,0,8,0"/>
            <Button Content="🧠 ОПТИМИЗАЦИЯ" Width="130" Height="32" Background="#9b59b6" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding OptimizeStrategyCommand}" Margin="0,0,8,0"/>
            <Button Content="📁 ЭКСПОРТ" Width="100" Height="32" Background="#3498db" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding ExportDataCommand}" Margin="0,0,8,0"/>
            <Button Content="🗑 ОЧИСТИТЬ ЛОГИ" Width="120" Height="32" Background="#e67e22" Foreground="White" BorderThickness="0" Cursor="Hand" Command="{Binding ClearLogsCommand}" Margin="0,0,8,0"/>
        </WrapPanel>

        <Border Grid.Row="1" Background="#1e1e1e" CornerRadius="5" Padding="10" Margin="0,8,0,8">
            <WrapPanel>
                <TextBlock Text="SMA:" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding FastSma}" Width="50" Margin="0,0,5,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>
                <TextBox Text="{Binding SlowSma}" Width="50" Margin="0,0,20,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>

                <TextBlock Text="RSI Buy &lt;" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding RsiBuyThreshold}" Width="50" Margin="0,0,5,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>
                <TextBlock Text="RSI Sell &gt;" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding RsiSellThreshold}" Width="50" Margin="0,0,20,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>

                <TextBlock Text="SL" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding StopLossPercent}" Width="50" Margin="0,0,5,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>
                <TextBlock Text="TP" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding TakeProfitPercent}" Width="50" Margin="0,0,5,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>
                <TextBlock Text="Trail" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding TrailingStopPercent}" Width="50" Margin="0,0,20,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>

                <TextBlock Text="Риск" Foreground="#bdc3c7" Margin="0,0,5,0" VerticalAlignment="Center"/>
                <TextBox Text="{Binding RiskPerTradePercent}" Width="50" Margin="0,0,5,0" Background="#2c3e50" Foreground="White" BorderBrush="#34495e" Height="28"/>
            </WrapPanel>
        </Border>

        <WrapPanel Grid.Row="2" Margin="0,0,0,10">
            <Border Background="#2c3e50" CornerRadius="8" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💰" FontSize="20" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="USDC BALANCE" Foreground="#7f8c8d" FontSize="10"/>
                        <TextBlock Text="{Binding WalletBalance}" Foreground="#2ecc71" FontWeight="Bold" FontSize="20"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#2c3e50" CornerRadius="8" Padding="12,8" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="20" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="POSITIONS" Foreground="#7f8c8d" FontSize="10"/>
                        <TextBlock Text="{Binding PositionsStatusText}" Foreground="#f39c12" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#2c3e50" CornerRadius="8" Padding="12,8" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🎯" FontSize="20" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="WIN RATE" Foreground="#7f8c8d" FontSize="10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding WinRate, StringFormat=F1}" Foreground="#2ecc71" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="%" Foreground="#2ecc71" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#2c3e50" CornerRadius="8" Padding="12,8" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📉" FontSize="20" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="MAX DRAWDOWN" Foreground="#7f8c8d" FontSize="10"/>
                        <TextBlock Text="{Binding MaxDrawdownDisplay}" Foreground="#e74c3c" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#2c3e50" CornerRadius="8" Padding="12,8" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📈" FontSize="20" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="TOTAL PNL" Foreground="#7f8c8d" FontSize="10"/>
                        <TextBlock Text="{Binding TotalPnL, StringFormat=F2}" Foreground="#3498db" FontWeight="Bold" FontSize="16"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#2c3e50" CornerRadius="8" Padding="12,8" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📡" FontSize="20" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="TELEGRAM" Foreground="#7f8c8d" FontSize="10"/>
                        <TextBlock Text="{Binding TelegramStatus}" Foreground="#3498db" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </WrapPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding PairsList}" 
                  AutoGenerateColumns="False" HeadersVisibility="Column"
                  Background="#121212" Foreground="White"
                  BorderThickness="0" FontSize="13"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single" RowHeight="32"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserResizeColumns="True" CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ПАРА" Binding="{Binding Pair}" Width="120"/>
                <DataGridTextColumn Header="ЦЕНА" Binding="{Binding Price}" Width="140"/>
                <DataGridTextColumn Header="СИГНАЛ" Binding="{Binding Analysis}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>